# MCP transport: "streamable-http" for HTTP (default) or "stdio" for local
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8080
MCP_PATH=/mcp

# The worker ID used for "current user" tools (get_current_user_info, etc.)
# Change this to simulate different logged-in users against the mock data.
CURRENT_USER_WORKER_ID=WK001
