# Chat Provider: "flowise" (recommended) or "openrouter" (demo/experiment)
CHAT_PROVIDER=flowise

# ─── LINE WORKS ───────────────────────────────────────────────
LW_API_20_CLIENT_ID=
LW_API_20_CLIENT_SECRET=
LW_API_20_SERVICE_ACCOUNT_ID=
LW_API_20_PRIVATEKEY=
LW_API_20_BOT_ID=
LW_API_20_BOT_SECRET=

# ─── Flowise (primary) ───────────────────────────────────────
# Full prediction endpoint URL, e.g. https://your-flowise.com/api/v1/prediction/<flow-id>
FLOWISE_API_URL=
FLOWISE_API_KEY=

# ─── OpenRouter (demo/experiment) ────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=z-ai/glm-4.5-air:free
OPENROUTER_SYSTEM_PROMPT=You are a helpful assistant.
# Options: high, medium, low, minimal, none
OPENROUTER_REASONING_EFFORT=

# ─── App ──────────────────────────────────────────────────────
PORT=8080
